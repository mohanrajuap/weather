# Required — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Required — your chat id(s). For MULTIPLE people, comma-separate:
#   TELEGRAM_CHAT_ID=123456789,987654321,555555555
TELEGRAM_CHAT_ID=123456789

# Optional — your public Polymarket wallet (for position context)
POLYMARKET_WALLET=0xYourAddressHere

# Optional — minutes between scans (default 20)
CHECK_INTERVAL_MIN=20

# Optional — minutes between position P&L updates (default 15, needs wallet)
POSITION_UPDATE_MIN=15

# Optional — tight watch on held positions, alerts on model flips (default 5 min)
POSITION_WATCH_MIN=5

# Optional — how often (min) to check custom /watch price alerts (default 3)
PRICE_WATCH_MIN=3

# ─────────────────────────────────────────────────────────────────────────────
# Endgame / closing-market scanner — a SEPARATE alert for markets that are nearly
# decided (only a few buckets still "alive"). It just SHOWS the bot's model pick
# for that market (no edge comparison — you decide). Manual scan: /endgame.
# ─────────────────────────────────────────────────────────────────────────────
# ENABLE_ENDGAME=1
# ENDGAME_MAX_ALIVE=3        # market counts as "ending" with <= this many alive buckets
# ENDGAME_ALIVE_CENTS=2      # a bucket is "alive" if its YES price is above this (¢)
# ENDGAME_DOMINANT=0.70      # one bucket must be the front-runner at >= this (0-1)

# ─────────────────────────────────────────────────────────────────────────────
# Outgoing webhook — forward every signal (with bias + no-bias values) to your
# OTHER bot's API as JSON. Leave WEBHOOK_URL blank to disable. Test with /webhook.
#   WEBHOOK_URL    = https://your-other-bot.example/api/signal
#   WEBHOOK_TOKEN  = sent as 'Authorization: Bearer <token>' (optional)
#   WEBHOOK_EVENTS = which events to forward (default new_signal,bucket_shift,collapse)
#   WEBHOOK_TIMEOUT= seconds (default 10)
# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK_URL=
# WEBHOOK_TOKEN=
# WEBHOOK_EVENTS=new_signal,bucket_shift,collapse
# WEBHOOK_TIMEOUT=10

# Optional — probability threshold 0-1 (default 0.70)
PROB_THRESHOLD=0.70

# Optional — fetch Polymarket prices in alerts (default 1)
USE_PRICES=1

# Optional — limit to specific cities (default: all 51)
# ALERT_CITIES=tokyo,london,milan,madrid

# Optional — state db path (Railway: use a volume at /data)
STATE_DB=/data/monitor_state.db

# Optional — fast re-check of active signals for drops (default 5 min)
SIGNAL_WATCH_MIN=5

# Optional — only alert on RELIABLE post-peak signals (default 0=off)
# Set to 1 to suppress speculative pre-peak/tomorrow signals
RELIABLE_ONLY=0

# Trade mode: LIVE = send buy/sell signal alerts (default).
#             OBSERVE = keep scanning, LEARNING, and tracking your held positions,
#                       but DON'T send buy alerts — gather accuracy/calibration
#                       data hands-off until you trust the bot. (Learning runs in
#                       BOTH modes; position & profit alerts fire in both too.)
TRADE_MODE=LIVE

# Wunderground (api.weather.com) settlement keys — comma-separated. Kept out of
# code for security; if unset the bot uses METAR / Open-Meteo for settlement.
# WU_KEYS=

# ─────────────────────────────────────────────────────────────────────────────
# Nightly GitHub backup of the learning data (off-Railway safety copy). Optional.
# Pushes learn_history.json + deb_history.json to a SEPARATE branch (so it never
# redeploys main). Leave GITHUB_TOKEN blank to disable.
#   GITHUB_TOKEN  = a fine-grained PAT for THIS repo with Contents: Read+Write
#   GITHUB_REPO   = owner/repo, e.g. mohanrajuap/weather
# ─────────────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=
# GITHUB_REPO=mohanrajuap/weather
# GITHUB_BACKUP_BRANCH=learning-data
# BACKUP_HOUR_UTC=2

# Optional — alert to book profit when a position is up this % (default 10)
PROFIT_TAKE_PCT=10

# Optional — your bankroll in USD. Used to turn the model's Kelly fraction into a
# concrete suggested stake in each alert ("bet $X", quarter-Kelly). Default 100.
# BANKROLL=100

# Optional — once-a-day "morning digest" of the best edges across all cities.
# ENABLE_DIGEST=1            # set 0 to turn the digest off
# DIGEST_HOUR_UTC=6          # hour (UTC) to send it (suppressed in OBSERVE mode)

# Optional — file storing /mute'd cities (persists across restarts).
# Defaults to /data/muted.json on Railway, ./muted.json locally.
# MUTE_FILE=

# ─────────────────────────────────────────────────────────────────────────────
# EXTRA FORECAST SOURCES (optional, free-tier) — set a key and that API joins the
# blend for every city automatically. More independent sources = tighter σ and
# better/correcter trade decisions. Values are auto-converted to each city's unit
# (°C/°F), so you never worry about what unit an API returns. Leave blank to skip.
# ─────────────────────────────────────────────────────────────────────────────
# OpenWeatherMap — free 1,000,000/mo — https://openweathermap.org/api
# OPENWEATHER_API_KEY=
# WeatherAPI.com — free 1,000,000/mo — https://www.weatherapi.com
# WEATHERAPI_KEY=
# Visual Crossing — free 1,000 records/day — https://www.visualcrossing.com
# VISUALCROSSING_KEY=
# Tomorrow.io — free ~500/day — https://www.tomorrow.io
# TOMORROW_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Resilience tuning (optional — sensible defaults already set)
# ─────────────────────────────────────────────────────────────────────────────
# HTTP_CACHE_TTL=1800        # seconds to cache forecast responses (default 1800)
# METAR_BATCH_TTL=900        # seconds to reuse the one-call airport-METAR batch
#                            # (all stations fetched in a single aviationweather.gov
#                            # request per scan; default 900 = 15 min)
# RATE_LIMIT_TRIP=3          # failures before a host's circuit breaker opens
# RATE_LIMIT_COOLDOWN=600    # seconds to pause a failing host
# LEARN_REPORT_HOURS=24      # how often to send the learning scoreboard to Telegram
# EDGE_MIN=0.10              # min model-vs-market edge to trade (raise = pickier)
# DEB_LOOKBACK=10            # days of history the bias learner remembers
# DEB_DECAY=0.85             # how fast old days fade in the learner (0-1)
# SOURCE_OUTLIER_TOL=8.0     # °C a source may differ from consensus before it's
#                            # auto-unit-corrected or dropped as a bad API
# CITY_BIAS=manila:2.0,karachi:0.5   # manual per-city bias (°). Overrides the
#                            # learned bias for that city. Use /history <city> —
#                            # it tells you the exact value to set.

# ─────────────────────────────────────────────────────────────────────────────
# Turn individual forecast sources OFF (all default ON; set to 0 to disable)
# ─────────────────────────────────────────────────────────────────────────────
# ENABLE_OPEN_METEO=1
# ENABLE_ENSEMBLE=1
# ENABLE_MULTIMODEL=1
# ENABLE_METNO=1
# ENABLE_NWS=1
# ENABLE_7TIMER=1

# ─────────────────────────────────────────────────────────────────────────────
# API endpoints — only set these if an API changes its URL (defaults are built in)
# ─────────────────────────────────────────────────────────────────────────────
# OPEN_METEO_URL= / OPEN_METEO_ENSEMBLE_URL= / METNO_URL= / NWS_POINTS_URL=
# SEVENTIMER_URL= / OPENWEATHER_URL= / WEATHERAPI_URL= / VISUALCROSSING_URL=
# TOMORROW_URL= / METAR_URL= / WUNDERGROUND_URL=
# POLYMARKET_GAMMA_URL= / POLYMARKET_CLOB_URL= / POLYMARKET_DATA_URL=
