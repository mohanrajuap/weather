# Required — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Required — your chat id(s). For MULTIPLE people, comma-separate:
#   TELEGRAM_CHAT_ID=123456789,987654321,555555555
TELEGRAM_CHAT_ID=123456789

# Optional — your public Polymarket wallet (for position context)
POLYMARKET_WALLET=0xYourAddressHere

# Optional — minutes between scans (default 20)
CHECK_INTERVAL_MIN=20

# Optional — minutes between position P&L updates (default 15, needs wallet)
POSITION_UPDATE_MIN=15

# Optional — tight watch on held positions, alerts on model flips (default 5 min)
POSITION_WATCH_MIN=5

# Optional — probability threshold 0-1 (default 0.70)
PROB_THRESHOLD=0.70

# Optional — fetch Polymarket prices in alerts (default 1)
USE_PRICES=1

# Optional — limit to specific cities (default: all 51)
# ALERT_CITIES=tokyo,london,milan,madrid

# Optional — state db path (Railway: use a volume at /data)
STATE_DB=/data/monitor_state.db

# Optional — fast re-check of active signals for drops (default 5 min)
SIGNAL_WATCH_MIN=5

# Optional — only alert on RELIABLE post-peak signals (default 0=off)
# Set to 1 to suppress speculative pre-peak/tomorrow signals
RELIABLE_ONLY=0

# Optional — alert to book profit when a position is up this % (default 10)
PROFIT_TAKE_PCT=10

# ─────────────────────────────────────────────────────────────────────────────
# EXTRA FORECAST SOURCES (optional, free-tier) — set a key and that API joins the
# blend for every city automatically. More independent sources = tighter σ and
# better/correcter trade decisions. Values are auto-converted to each city's unit
# (°C/°F), so you never worry about what unit an API returns. Leave blank to skip.
# ─────────────────────────────────────────────────────────────────────────────
# OpenWeatherMap — free 1,000,000/mo — https://openweathermap.org/api
# OPENWEATHER_API_KEY=
# WeatherAPI.com — free 1,000,000/mo — https://www.weatherapi.com
# WEATHERAPI_KEY=
# Visual Crossing — free 1,000 records/day — https://www.visualcrossing.com
# VISUALCROSSING_KEY=
# Tomorrow.io — free ~500/day — https://www.tomorrow.io
# TOMORROW_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Resilience tuning (optional — sensible defaults already set)
# ─────────────────────────────────────────────────────────────────────────────
# HTTP_CACHE_TTL=1800        # seconds to cache forecast responses (default 1800)
# RATE_LIMIT_TRIP=3          # failures before a host's circuit breaker opens
# RATE_LIMIT_COOLDOWN=600    # seconds to pause a failing host
# LEARN_REPORT_HOURS=24      # how often to send the learning scoreboard to Telegram
