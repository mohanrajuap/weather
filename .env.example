# Required — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Required — your chat id(s). For MULTIPLE people, comma-separate:
#   TELEGRAM_CHAT_ID=123456789,987654321,555555555
TELEGRAM_CHAT_ID=123456789

# Optional — your public Polymarket wallet (for position context)
POLYMARKET_WALLET=0xYourAddressHere

# Optional — minutes between scans (default 20)
CHECK_INTERVAL_MIN=10

# Optional — minutes between position P&L updates (default 15, needs wallet)
POSITION_UPDATE_MIN=10

# Optional — tight watch on held positions, alerts on model flips (default 5 min)
POSITION_WATCH_MIN=5

# Optional — probability threshold 0-1 (default 0.70)
PROB_THRESHOLD=0.70

# Optional — fetch Polymarket prices in alerts (default 1)
USE_PRICES=1

# Optional — limit to specific cities (default: all 51)
# ALERT_CITIES=tokyo,london,milan,madrid

# Optional — state db path (Railway: use a volume at /data)
STATE_DB=/data/monitor_state.db
